    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.9.0",
    "@types/passport-jwt": "^4.0.1",
    "jest": "^29.7.0",
