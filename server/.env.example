NODE_ENV=development
PORT=3001

# Database
DATABASE_URL=postgresql://foundation:foundation@localhost:5432/foundation

# Redis
REDIS_URL=redis://localhost:6379

# Auth0
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_AUDIENCE=https://api.foundation.app

# Plaid
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# QuickBooks
QB_CLIENT_ID=
QB_CLIENT_SECRET=
QB_REDIRECT_URI=http://localhost:3001/api/integrations/quickbooks/callback

# Claude API (reads from file at /tmp/api-key)
ANTHROPIC_API_KEY=

# App
FRONTEND_URL=http://localhost:5173
JWT_SECRET=change-me-in-production
